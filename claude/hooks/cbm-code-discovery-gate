#!/bin/bash
# codebase-memory-mcp search augmenter (Claude Code PreToolUse).
# Despite the legacy filename this NEVER blocks a tool call -- it only adds
# graph context to Grep/Glob. Any failure is silent (exit 0, no output).
# Filename kept so settings.json entries need no migration.
BIN="$HOME/.local/bin/codebase-memory-mcp"
[ -x "$BIN" ] || exit 0
"$BIN" hook-augment 2>/dev/null
exit 0
